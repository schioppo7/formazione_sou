Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"

  #Provisioning per installare Docker 
  config.vm.provision "shell", inline: <<-SHELL
    apt-get update -y && apt-get install -y docker.io
    systemctl start docker
    usermod -aG docker vagrant #utilizzare vagrant per eseguire docker senza sudo
  SHELL

  #Provisioning per il ping pong script
  config.vm.provision "file", source: "./ping_pong.sh", destination: "/tmp/ping_pong.sh" #copia lo script ping_pong.sh nella VM
config.vm.provision "shell", inline: <<-SHELL #
    mv /tmp/ping_pong.sh /usr/local/bin/ping_pong.sh 
    chmod +x /usr/local/bin/ping_pong.sh #rende eseguibile lo script
    echo "* * * * * /usr/local/bin/ping_pong.sh
  SHELL

  # Nodo 1 
  config.vm.define "node1" do |n| 
    n.vm.hostname = "node1" 
    n.vm.network "private_network", ip: "192.168.56.11"
  end

  # Nodo 2
  config.vm.define "node2" do |n|
    n.vm.hostname = "node2"
    n.vm.network "private_network", ip: "192.168.56.12" 
  end 
end